<%= form_with url: search_conditions_path, method: :get, data: { turbo_frame: "conditions_results" } do |f| %>
  <%= f.text_field :query, placeholder: "Search conditions...", class: "border rounded px-3 py-2 w-full" %>
  <%= f.submit "Search", class: "mt-2 bg-blue-600 text-white px-4 py-2 rounded" %>
<% end %>

<%= turbo_frame_tag "conditions_results" do %>
  <% if @conditions&.any? %>
    <% @conditions.each do |condition| %>
      <div><%= condition.name %></div>
    <% end %>
  <% end %>
<% end %>
